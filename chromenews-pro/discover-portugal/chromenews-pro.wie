{"sidebar-1":{"block-8":{"content":"<!-- wp:search {\"label\":\"Procurar\",\"buttonText\":\"Search\"} \/-->"},"block-13":{"content":"<!-- wp:group {\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:heading -->\n<h2 class=\"wp-block-heading\">\u00daltima postagem<\/h2>\n<!-- \/wp:heading -->\n\n<!-- wp:latest-posts \/--><\/div>\n<!-- \/wp:group -->"},"block-17":{"content":"<!-- wp:group {\"layout\":{\"type\":\"constrained\"}} -->\n<div class=\"wp-block-group\"><!-- wp:heading -->\n<h2 class=\"wp-block-heading\">Categorias<\/h2>\n<!-- \/wp:heading -->\n\n<!-- wp:categories \/--><\/div>\n<!-- \/wp:group -->"}}}