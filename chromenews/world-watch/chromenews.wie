 \u0938\u092e\u092f \u092e\u0947\u0902 \u090f\u0915 \u0906\u0915\u0930\u094d\u0937\u0915, \u092a\u0947\u0936\u0947\u0935\u0930 \u0914\u0930 \u0906\u0938\u093e\u0928\u0940 \u0938\u0947 \u0930\u0916\u0930\u0916\u093e\u0935 \u092f\u094b\u0917\u094d\u092f \u0935\u0947\u092c\u0938\u093e\u0907\u091f \u092c\u0928\u093e \u0938\u0915\u0924\u0947 \u0939\u0948\u0902\u0964\",\"filter\":true,\"visual\":true}}} \/-->\n\n<!-- wp:buttons -->\n<div class=\"wp-block-buttons\"><!-- wp:button {\"textColor\":\"black\",\"className\":\"is-style-outline\",\"style\":{\"color\":{\"background\":\"#ffc934\"}}} -->\n<div class=\"wp-block-button is-style-outline\"><a class=\"wp-block-button__link has-black-color has-text-color has-background wp-element-button\" href=\"https:\/\/afthemes.com\/all-themes-plan\/\" style=\"background-color:#ffc934\" target=\"_blank\" rel=\"noreferrer noopener\">\u0938\u092d\u0940 \u0925\u0940\u092e \u092a\u094d\u0932\u093e\u0928 \u091a\u0941\u0928\u0947\u0902<\/a><\/div>\n<!-- \/wp:button --><\/div>\n<!-- \/wp:buttons --><\/div>\n<!-- \/wp:group -->"}},"footer-second-widgets-section":{"recent-posts-3":{"title":"\u0939\u093e\u0932\u093f\u092f\u093e \u092a\u094b\u0938\u094d\u091f","number":5,"show_date":false}},"footer-third-widgets-section":{"tag_cloud-3":[],"tag_cloud-4":{"title":"\u0936\u094d\u0930\u0947\u0923\u093f\u092f\u093e\u0901","count":0,"taxonomy":"category"}}}